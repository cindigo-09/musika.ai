# Musika AI - Backend Environment Variables
# Fill these in the Render dashboard (never commit real values!)

SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (for admin operations like deleting users)
ROLE_KEY=your_supabase_service_role_key_here

# Jamendo API (for music recommendations)
JAMENDO_CLIENT_ID=your_jamendo_client_id_here
